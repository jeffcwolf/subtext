# ─── Rust ────────────────────────────────────────────────────────────
/target/
**/*.rs.bk                 # rustfmt backups
# Cargo.lock: COMMIT it for binaries/apps (reproducible builds).
# Ignore it ONLY for library crates. This repo is an app → keep it tracked.

# ─── Leptos / WASM ───────────────────────────────────────────────────
/pkg/
/dist/

# ─── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
.venv/
**/.venv/                  # venvs in subprojects (e.g. pipeline/.venv)
# uv.lock: COMMIT it (reproducible environments) — do NOT ignore.

# Python tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ─── Generated data caches (built by the pipeline, read by the app) ──
data/*.db
data/*.sqlite
data/*.json
!data/.gitkeep
data/
# If you ship a committed demo fixture, re-include it explicitly:
# !data/sample.db

# ─── Secrets / environment ───────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Editors / IDEs ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
